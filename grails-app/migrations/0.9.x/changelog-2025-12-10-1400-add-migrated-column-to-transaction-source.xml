<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="kchelstowski" id="101220251400-0">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="transaction_source" columnName="migrated"/>
            </not>
        </preConditions>

        <addColumn tableName="transaction_source">
            <column name="migrated" type="BIT" defaultValueBoolean="false" />
        </addColumn>
    </changeSet>
</databaseChangeLog>
