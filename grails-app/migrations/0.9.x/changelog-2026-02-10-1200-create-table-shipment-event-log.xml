<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <!-- Shipment has GORM's "hasMany" on EventLog, resulting in this mapping table from shipment to event log -->

    <changeSet author="ewaterman" id="100220261200-0">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="shipment_event_log"/>
            </not>
        </preConditions>
        
        <createTable tableName="shipment_event_log">
            <column name="shipment_id" type="CHAR(38)">
                <constraints nullable="false" />
            </column>
            <column name="event_log_id" type="CHAR(38)">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet author="ewaterman" id="100220261200-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_shipment_event_log_shipment"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
                baseColumnNames="shipment_id"
                baseTableName="shipment_event_log"
                constraintName="fk_shipment_event_log_shipment"
                deferrable="false"
                initiallyDeferred="false"
                referencedColumnNames="id"
                referencedTableName="shipment"
        />
    </changeSet>

    <changeSet author="ewaterman" id="100220261200-2">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_shipment_event_log_event_log"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
                baseColumnNames="event_log_id"
                baseTableName="shipment_event_log"
                constraintName="fk_shipment_event_log_event_log"
                deferrable="false"
                initiallyDeferred="false"
                referencedColumnNames="id"
                referencedTableName="event_log"
        />
    </changeSet>
</databaseChangeLog>
