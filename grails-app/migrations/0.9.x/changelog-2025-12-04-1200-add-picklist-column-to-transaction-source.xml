<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="awalkowiak" id="041220251200-0">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="transaction_source" columnName="picklist_id"/>
            </not>
        </preConditions>

        <addColumn tableName="transaction_source">
            <column name="picklist_id" type="CHAR(38)">
                <constraints nullable="true" />
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="awalkowiak" id="041220251200-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transaction_source_picklist"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
                baseColumnNames="picklist_id"
                baseTableName="transaction_source"
                constraintName="fk_transaction_source_picklist"
                deferrable="false"
                initiallyDeferred="false"
                referencedColumnNames="id"
                referencedTableName="picklist"
        />
    </changeSet>
</databaseChangeLog>
