                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9 http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">

    <changeSet author="druchniewicz" id="211120251300-0">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="picklist_item" columnName="outbound_container_id"/></not>
        </preConditions>
        <addColumn tableName="picklist_item">
            <column name="outbound_container_id" type="CHAR(38)"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="picklist_item" baseColumnNames="outbound_container_id"
                                 referencedTableName="location" referencedColumnNames="id"
                                 constraintName="fk_picklist_item_outbound_container"/>
    </changeSet>

